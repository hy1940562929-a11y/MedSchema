          "轻微阳性症状"
        ]
      },
      {
        "is_negative": false,
        "name": "归属症状",
        "arguments": [
          "Y",
          "X"
        ]
      },
      {
        "is_negative": false,
        "name": "症状时间条件",
        "arguments": [
          "Y",
          "出现在过去1年内"
        ]
      },
      {
        "is_negative": false,
        "name": "症状频率",
        "arguments": [
          "Y",
          "平均至少每周1次"
        ]
      },
      {
        "is_negative": false,
        "name": "症状影响",
        "arguments": [
          "Y",
          "对日常造成困扰"
        ]
      },
      {
        "is_negative": false,
        "name": "症状自知力",
        "arguments": [
          "Y",
          "保有自知力"
        ]
      }
    ],
    "variables": {
      "X": "患者",
      "Y": "症状"
    },
    "source_text": "是指在不长一段时间内（多指定为1 年内，或者最近1 年内轻微阳性症状严重程度比1 年前有进行性加重）出现轻微阳性症状，如幻觉、怪异思维，但程度比精神病性症状轻，主要体现在对这些异常体验和思维具有较完整的现实检验能力，有自知力。（Ⅰ，A）操作标准：患者轻微阳性症状出现在过去1年内（或者症状严重程度在最近1 年有显著加重），轻微阳性症状对患者日常造成困扰，但未达到精神病性严重程度（即对症状保有自知力），轻微阳性症状出现频率在过去的1 个月中必须平均至少每周1 次。（Ⅰ，A）"
  },

  {
    "rule_name": "轻微阳性症状综合征诊断标准_时间条件_出现于过去1年",
    "head": {
      "is_negative": false,
      "name": "患者类型",
      "arguments": [
        "X",
        "轻微阳性症状综合征"
      ]

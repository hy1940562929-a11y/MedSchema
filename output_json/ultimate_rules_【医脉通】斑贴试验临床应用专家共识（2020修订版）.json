          "Z"
        ]
      },
      {
        "is_negative": false,
        "name": "变应原存在于",
        "arguments": [
          "Z",
          "患者使用产品"
        ]
      },
      {
        "is_negative": false,
        "name": "皮炎部位与",
        "arguments": [
          "X",
          "产品使用部位一致"
        ]
      },
      {
        "is_negative": false,
        "name": "规避后症状消失",
        "arguments": [

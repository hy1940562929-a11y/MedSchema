  {
    "rule_name": "腹腔镜阴道骶骨固定术指征_有症状穹隆脱垂",
    "head": {
      "is_negative": false,
      "name": "手术推荐方案",
      "arguments": [
        "X",
        "腹腔镜阴道骶骨固定术",
        "主要适应证"

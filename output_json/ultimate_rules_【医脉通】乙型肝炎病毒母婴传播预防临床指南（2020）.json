  {
    "rule_name": "本指南推荐_口服抗病毒药阈值_HBV_DNA_大于_2E5",
    "head": {
      "is_negative": false,
      "name": "用药指征",
      "arguments": [
        "X",
        "口服抗病毒药物",
        "推荐"
      ]
    },
    "body": [
      {
        "is_negative": false,
        "name": "孕妇",
        "arguments": [
          "X"
        ]
      },
      {
        "is_negative": false,
        "name": "病毒指标",
        "arguments": [
          "X",
          "HBV_DNA_大于_2E5_kIU_L"
        ]
      },
      {
        "is_negative": false,
        "name": "检测条件",
        "arguments": [
          "综合考虑国产试剂"
        ]
      }
    ],
    "variables": {
      "X": "孕妇"
    },
    "source_text": "目前尚无引起母婴传播的母体病毒水平的确切阈值，在查阅国内外相关资料［3，6，13⁃26］的基础上，结合国产试剂检测结果综合考虑，本指南推荐以HBV DNA水平>2×105 kIU/L（即IU/ml）为口服抗病毒药物预防母婴传播的阈值。"
  },
  {
    "rule_name": "无需口服抗病毒药_当_HBV_DNA_低载量_且_新生儿正规预防",
    "head": {
      "is_negative": true,
      "name": "用药指征",
      "arguments": [
        "X",
        "口服抗病毒药物",
        "推荐"
      ]
    },
    "body": [
      {
        "is_negative": false,
        "name": "孕妇",
        "arguments": [
          "X"
        ]
      },
      {
        "is_negative": false,
        "name": "病毒指标",
        "arguments": [
          "X",
          "HBV_DNA_小于等于_2E5_kIU_L"
        ]
      },
      {
        "is_negative": false,
        "name": "新生儿干预",
        "arguments": [
          "正规免疫预防"
        ]
      }
    ],
    "variables": {
      "X": "孕妇"
    },
    "source_text": "研究证明，HBV DNA水平≤106 kIU/L（即IU/ml）的孕妇的新生儿经及时、正规的免疫预防后，几乎不发生母婴传播［3，6，9，25⁃26］。因此，将HBV DNA>2×105 kIU/L 作为口服抗病毒药物预防母婴传播的阈值是保守的，对HBV DNA≤2×105 kIU/L（即IU/ml）孕妇无需口服抗病毒药物。"
  },
  {
    "rule_name": "无HBV_DNA检测地区_以_HBeAg阳性_为用药指征",
    "head": {

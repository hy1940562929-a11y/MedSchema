  {
    "rule_name": "基于前瞻性研究的_HBV_DNA高载量孕妇_妊娠晚期抗病毒推荐",
    "head": {
      "is_negative": false,
      "name": "用药推荐",
      "arguments": [
        "X",
        "抗病毒药物",
        "妊娠晚期"
      ]
    },
    "body": [
      {
        "is_negative": false,
        "name": "孕妇",
        "arguments": [
          "X"
        ]
      },
      {
        "is_negative": false,
        "name": "病毒指标",
        "arguments": [
          "X",
          "HBV_DNA_大于_106kIU_L"
        ]
      },
      {
        "is_negative": false,
        "name": "妊娠阶段",
        "arguments": [
          "X",
          "28_32周"
        ]
      },
      {
        "is_negative": false,
        "name": "新生儿干预",
        "arguments": [
          "正规免疫预防"
        ]
      }
    ],
    "variables": {
      "X": "孕妇"
    },
    "source_text": "多项前瞻性临床研究表明，对HBV DNA水平>106kIU/L（即IU/ml）或HBeAg阳性孕妇妊娠晚期（妊娠28~32 周）开始服用抗病毒药物，使孕妇分娩时病毒水平降低，同时新生儿正规免疫接种预防，几乎可完全阻断HBV 母婴传播［13⁃19］。"
  },

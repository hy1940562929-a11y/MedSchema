  {
    "rule_name": "卟啉病病因与核心病理",
    "head": {
      "is_negative": false,
      "name": "代谢性疾病",
      "arguments": [
        "X",
        "卟啉病"
      ]
    },
    "body": [
      {
        "is_negative": false,
        "name": "酶活性缺乏",
        "arguments": [
          "X",
          "血红素生物合成途径"
        ]
      },
      {
        "is_negative": false,
        "name": "导致",
        "arguments": [
          "X",
          "浓度升高"
        ]
      },
      {
        "is_negative": false,
        "name": "蓄积",
        "arguments": [
          "浓度升高",
          "组织"
        ]
      },
      {
        "is_negative": false,
        "name": "造成",
        "arguments": [
          "蓄积",
          "细胞损伤"
        ]
      }
    ],
    "variables": {
      "X": "生理状态"
    },
    "source_text": "卟啉病（Porphyria）是由于血红素生物合成途径中的酶活性缺乏，引起卟啉或其前体［如δ⁃氨基乙酰丙酸（delta⁃aminolevulinic acid，δ⁃ALA）和卟胆原（porphobilinogen，PBG）］浓度异常升高，并在组织中蓄积，造成细胞损伤而引起的一类代谢性疾病。"
  },
  {
    "rule_name": "血红素合成路径_初始反应",
    "head": {
      "is_negative": false,
      "name": "催化合成",
      "arguments": [
        "ALAS",
        "δ⁃ALA"
      ]
    },
    "body": [
      {
        "is_negative": false,
        "name": "底物",
        "arguments": [
          "反应",
          "甘氨酸"
        ]
      },
      {
        "is_negative": false,
        "name": "底物",
        "arguments": [
          "反应",
          "琥珀酰辅酶A"
        ]
      },
      {
        "is_negative": false,
        "name": "酶",
        "arguments": [
          "反应",
          "ALAS"
        ]
      },
      {
        "is_negative": false,
        "name": "产物",
        "arguments": [
          "反应",
          "δ⁃ALA"
        ]
      }
    ],
    "variables": {
      "ALAS": "酶实体",
      "反应": "化学反应事件"
    },
    "source_text": "血红素的合成经过一系列酶促反应：甘氨酸与琥珀酰辅酶A在5⁃氨基乙酰丙酸合成酶（ALAS）作用下合成δ⁃ALA，经ALA脱水酶催化形成PBG。"
  },
  {
    "rule_name": "血红素合成路径_后续反应链",
    "head": {
      "is_negative": false,
      "name": "合成血红素",
      "arguments": [
        "路径"
      ]
    },
    "body": [
      {
        "is_negative": false,
        "name": "催化转化",
        "arguments": [
          "ALA脱水酶",
          "δ⁃ALA",
          "PBG"
        ]
      },
      {
        "is_negative": false,
        "name": "催化合成",
        "arguments": [
          "HMBS与尿卟啉原合成酶",
          "PBG",
          "尿卟啉原"
        ]
      },
      {
        "is_negative": false,
        "name": "转化",
        "arguments": [
          "尿卟啉原",
          "粪卟啉原"
        ]
      },
      {
        "is_negative": false,
        "name": "转化",
        "arguments": [
          "粪卟啉原",
          "原卟啉原Ⅸ"
        ]
      },
      {
        "is_negative": false,
        "name": "形成",
        "arguments": [
          "原卟啉原Ⅸ",
          "原卟啉Ⅸ"
        ]
      },
      {
        "is_negative": false,
        "name": "催化结合",
        "arguments": [
          "亚铁螯合酶",
          "原卟啉Ⅸ",
          "二价铁",
          "血红素"
        ]
      }
    ],
    "variables": {
      "路径": "合成过程"
    },
    "source_text": "多数PBG在羟甲基胆素合成酶（HMBS）和尿卟啉原合成酶作用下合成尿卟啉原，再转化为粪卟啉原、原卟啉原Ⅸ，形成原卟啉Ⅸ，在亚铁螯合酶催化下与二价铁结合成血红素。"
  },
  {
    "rule_name": "X连锁原卟啉病遗传与生化机制",
    "head": {
      "is_negative": false,
      "name": "疾病实体",
      "arguments": [
        "XLPP",
        "卟啉病"
      ]
    },
    "body": [
      {
        "is_negative": false,

        "name": "突变类型",
        "arguments": [
          "ALAS2",
          "功能获得性"
        ]
      },
      {
        "is_negative": false,
        "name": "遗传方式",
        "arguments": [
          "XLPP",
          "X连锁"
        ]
      },
      {
        "is_negative": false,

          "XLPP"
        ]
      },
      {
        "is_negative": false,
        "name": "生化表现",
        "arguments": [
          "XLPP",
          "原卟啉增加"
        ]
      }
    ],
    "variables": {
      "XLPP": "疾病实体",
      "ALAS2": "基因实体"
    },
    "source_text": "（1）X 连锁原卟啉病（XLPP）：ALAS2 基因位于X 染色体，编码血红素生物合成途径的初始酶，ALAS2 基因功能获得性突变引起XLPP，又称为X⁃连锁红细胞生成性原卟啉病（XLEPP），遗传方式为X⁃连锁遗传。患者红细胞中原卟啉生成增加，锌原卟啉增加。"
  },

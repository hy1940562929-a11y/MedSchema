  {
    "rule_name": "无低血糖的年轻DM患者设定严格HbA1c目标_下限",
    "head": {
      "is_negative": false,
      "name": "血糖控制目标",
      "arguments": [
        "X",
        "HbA1c小于6.0%",
        "严格"
      ]
    },
    "body": [
      {
        "is_negative": false,
        "name": "DM患者",
        "arguments": [
          "X"
        ]
      },
      {
        "is_negative": false,

        "name": "采集自",
        "arguments": [
          "Y",
          "X"
        ]
      },
      {
        "is_negative": false,
        "name": "患者",
        "arguments": [
          "X"
        ]
      },
      {
        "is_negative": false,
        "name": "临床方法",
        "arguments": [
          "X",
          "深部咳痰"
        ]
      },
      {
        "is_negative": false,
        "name": "采集前准备",
        "arguments": [
          "X",
          "清洁口腔"
        ]
      },
      {
        "is_negative": false,
        "name": "采集过程",
        "arguments": [
          "Y",
          "深咳取痰"
        ]
      },
      {
        "is_negative": false,
        "name": "有人员指导",
        "arguments": [
          "X",
          "Z"
        ]
      },
      {
        "is_negative": false,
        "name": "医务人员",
        "arguments": [
          "Z"
        ]
      },
      {
        "is_negative": false,
        "name": "送检频率",
        "arguments": [
          "Y",
          "每天1次"
        ]
      },
      {
        "is_negative": false,
        "name": "送检持续",
        "arguments": [
          "Y",
          "连续2至3天"
        ]
      },
      {
        "is_negative": false,
        "name": "送检后处理",
        "arguments": [
          "Y",
          "1至2小时内"
        ]
      }
    ],
    "variables": {
      "X": "患者",
      "Y": "痰标本",
      "Z": "医务人员"
    },
    "source_text": "其中深部咳痰法无创伤，患者或家属较易接受，临床应用较多；采集痰标本前应摘去义齿、牙托等，清洁口腔，深咳取痰，采集过程中最好有医务人员指导；不能主动咳痰的患者需要拍背排痰。痰标本每天送检1次，连续2～3 d做痰涂片和痰培养；采集后1～2 h之内须立即进行实验室处理。"
  },
  {
    "rule_name": "成人血培养标本采集规范",
    "head": {
      "is_negative": false,
      "name": "执行检查流程",
      "arguments": [
        "W",
        "血培养"
      ]
    },
    "body": [
      {
        "is_negative": false,
        "name": "血培养标本",
        "arguments": [
          "W"
        ]
      },
      {
        "is_negative": false,
        "name": "采集自",
        "arguments": [
          "W",
          "X"
        ]
      },
      {
        "is_negative": false,
        "name": "成人患者",
        "arguments": [
          "X"
        ]
      },
      {
        "is_negative": false,
        "name": "采集套数",
        "arguments": [
          "W",
          "2至3套"
        ]
      },
      {
        "is_negative": false,
        "name": "不同穿刺点采集",
        "arguments": [
          "W"
        ]
      },
      {
        "is_negative": false,
        "name": "采血时机",
        "arguments": [
          "X",
          "寒战或发热初起"
        ]
      },
      {
        "is_negative": false,
        "name": "注入顺序",
        "arguments": [
          "W",
          "厌氧后需氧"
        ]
      },
      {
        "is_negative": false,
        "name": "每瓶采血量",
        "arguments": [
          "W",
          "8至10mL"
        ]
      }
    ],
    "variables": {
      "X": "成人患者",
      "W": "血培养标本"
    },
    "source_text": "血培养是诊断血流感染的重要方法，成人每次应采集2～3套，每套从不同穿刺点进行采集。从同一穿刺点采集的血液标本通常按顺序注入厌氧和需氧培养瓶，每瓶采血量为8～10 mL，以提高阳性率。采血应在寒战或发热初起时进行。"
  },
  {

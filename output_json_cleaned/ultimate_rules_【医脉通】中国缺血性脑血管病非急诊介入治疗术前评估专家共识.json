  {
    "rule_name": "症状性颅内动脉狭窄患者短期双重抗血小板治疗获益",
    "head": {
      "is_negative": false,
      "name": "治疗获益",
      "arguments": [
        "X",
        "阿司匹林联合氯吡格雷短期治疗",
        "减少微栓子且未增加出血风险"
      ]
    },
    "body": [
      {
        "is_negative": false,
        "name": "脑血管病患者",
        "arguments": [
          "X"
        ]
      },
      {
        "is_negative": false,
        "name": "疾病亚型",
        "arguments": [
          "X",
          "缺血性卒中或TIA"
        ]
      },
      {
        "is_negative": false,
        "name": "伴随病理",
        "arguments": [
          "X",
          "症状性颅内动脉狭窄"
        ]
      }
    ],
    "variables": {
      "X": "患者"
    },
    "source_text": "对于伴有症状性颅内动脉狭窄的缺血性卒中和TIA患者，短期内给予阿司匹林联合氯吡格雷治疗可显著减少微栓子数量，且未增加出血风险［60‐61］。"
  },
  {
    "rule_name": "症状性颈动脉狭窄患者双重抗血小板治疗减少栓塞",
    "head": {
      "is_negative": false,
      "name": "治疗获益",
      "arguments": [
        "X",
        "氯吡格雷联合阿司匹林治疗",
        "减少非症状性栓塞"
      ]
    },
    "body": [
      {
        "is_negative": false,
        "name": "脑血管病患者",
        "arguments": [
          "X"
        ]
      },
      {
        "is_negative": false,
        "name": "伴随病理",
        "arguments": [
          "X",
          "症状性颈动脉狭窄"
        ]
      }
    ],
    "variables": {
      "X": "患者"
    },
    "source_text": "对于症状性颈动脉狭窄患者，CARESS试验结果显示，氯吡格雷（75 mg/d）联合阿司匹林（75 md/d）治疗能减少非症状性栓塞的发生［62］。"
  },
  {
    "rule_name": "亚洲患者西洛他唑预防血管事件不劣于阿司匹林",
    "head": {
      "is_negative": false,
      "name": "药物疗效对比",
      "arguments": [
        "X",
        "西洛他唑",
        "不劣于阿司匹林"
      ]
    },
    "body": [
      {
        "is_negative": false,
        "name": "脑血管病患者",
        "arguments": [
          "X"
        ]
      },
      {
        "is_negative": false,

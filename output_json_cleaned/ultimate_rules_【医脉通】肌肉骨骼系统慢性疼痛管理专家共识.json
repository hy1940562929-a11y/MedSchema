  {
    "rule_name": "慢性继发性肌肉骨骼疼痛分类_持续炎症机制",
    "head": {
      "is_negative": false,
      "name": "疼痛分类",
      "arguments": [
        "Y",
        "慢性继发性肌肉骨骼疼痛"
      ]
    },
    "body": [
      {
        "is_negative": false,
        "name": "患病",
        "arguments": [

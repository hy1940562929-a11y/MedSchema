  {
    "rule_name": "溶栓时间窗内急性缺血性卒中患者的替罗非班联合治疗合理性",
    "head": {
      "is_negative": false,
      "name": "治疗推荐",
      "arguments": [
        "X",
        "替罗非班",
        "辅助静脉溶栓_合理"
      ]
    },
    "body": [
